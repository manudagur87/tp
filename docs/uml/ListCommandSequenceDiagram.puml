@startuml
title ListCommand Sequence Diagram

actor User
participant ":Medistock" as App
participant ":Ui" as Ui
participant ":Parser" as Parser
participant ":ListCommand" as ListCommand
participant ":Inventory" as Inventory

User -> App : run "list"
activate App

App -> Ui : getInput()
activate Ui
Ui --> App : input:String
deactivate Ui

App -> Parser : parseCommand(input:String)
activate Parser

create ListCommand
Parser -> ListCommand : new ListCommand()
activate ListCommand
ListCommand --> Parser : command:ListCommand
deactivate ListCommand

Parser --> App : command:ListCommand
deactivate Parser

App -> ListCommand : execute(inventory:Inventory, ui:Ui)
activate ListCommand

ListCommand -> Ui : showInventoryList(inventory:Inventory)
activate Ui

Ui -> Inventory : getSize()
activate Inventory
Inventory --> Ui : size:int
deactivate Inventory

alt size == 0
  Ui -> Ui : printEmptyInventoryMessage()
  activate Ui
  deactivate Ui
else size > 0
  Ui -> Inventory : getActiveBatches()
  activate Inventory
  Inventory --> Ui : activeItems: List<InventoryItem>
  deactivate Inventory

  alt activeItems.isEmpty()
    Ui -> Ui : print("No active batches found.")
    activate Ui
    deactivate Ui
  else has active items
    loop each active item
      Ui -> Ui : printActiveItemDetails(...)
      activate Ui
      deactivate Ui
    end
  end

  Ui -> Inventory : getExpiredBatches()
  activate Inventory
  Inventory --> Ui : expiredItems: List<InventoryItem>
  deactivate Inventory

  alt expiredItems.isEmpty()
    Ui -> Ui : print("No expired batches found.")
    activate Ui
    deactivate Ui
  else has expired items
    loop each expired item
      Ui -> Ui : printExpiredItemDetails(...)
      activate Ui
      deactivate Ui
    end
  end
end

Ui --> ListCommand : return
deactivate Ui

ListCommand --> App : return
deactivate ListCommand

App --> User : inventory displayed
deactivate App
@enduml